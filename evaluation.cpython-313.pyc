from __future__ import annotations

import json
from pathlib import Path

from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, roc_auc_score
import matplotlib.pyplot as plt

from .evaluation import build_roc_frame
from .feature_extraction import build_feature_frames
from .io_utils import ensure_output_dir, load_dataset
from .naive_bayes import MultinomialNaiveBayes


def run_pipeline(data_path: str | Path, output_dir: str | Path = "outputs") -> dict:
    raw_df = load_dataset(data_path)
    output_path = ensure_output_dir(output_dir)

    train_features, test_features = build_feature_frames(raw_df)
    train_features[["Message ID", "features_json"]].to_csv(output_path / "train-features.tsv", sep="\t", index=False)
    test_features[["Message ID", "features_json"]].to_csv(output_path / "test-features.tsv", sep="\t", index=False)

    model = MultinomialNaiveBayes(alpha=1.0).fit(train_features, raw_df)
    feature_probabilities = model.feature_probabilities_frame()
    feature_probabilities.to_csv(output_path / "feature-probabilities.tsv", sep="\t", index=False)

    train_predictions = model.predict_frame(train_features)
    test_predictions = model.predict_frame(test_features)
    train_predictions.to_csv(output_path / "train-predictions.tsv", sep="\t", index=False)
    test_predictions.to_csv(output_path / "test-predictions.tsv", sep="\t", index=False)

    roc_frame = build_roc_frame(test_predictions, raw_df)
    roc_frame.to_csv(output_path / "roc.tsv", sep="\t", index=False)

    labeled_test = test_predictions.merge(raw_df[["Message ID", "Spam/Ham"]], on="Message ID", how="left")
    y_true = labeled_test["Spam/Ham"].map({"ham": 0, "spam": 1})
    y_score = labeled_test["spam"]
    y_pred = (y_score >= 0.5).astype(int)

    metrics = {
        "dataset_rows": int(len(raw_df)),
        "train_rows": int(len(train_features)),
        "test_rows": int(len(test_features)),
        "accuracy_at_0_5": float(accuracy_score(y_true, y_pred)),
        "precision_at_0_5": float(precision_score(y_true, y_pred)),
        "recall_at_0_5": float(recall_score(y_true, y_pred)),
        "f1_at_0_5": float(f1_score(y_true, y_pred)),
        "roc_auc": float(roc_auc_score(y_true, y_score)),
        "num_features_in_vocabulary": int(len(model.vocabulary_)),
    }

    with (output_path / "metrics.json").open("w", encoding="utf-8") as file:
        json.dump(metrics, file, indent=2)

    plt.figure(figsize=(7, 5))
    plt.plot(roc_frame["false_positive_rate"], roc_frame["true_positive_rate"])
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title("ROC Curve - Enron Spam Classifier")
    plt.tight_layout()
    plt.savefig(output_path / "roc_curve.png", dpi=160)
    plt.close()

    return metrics
